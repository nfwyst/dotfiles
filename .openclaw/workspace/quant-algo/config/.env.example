# ============================================================
# Quant-Algo Environment Configuration
# Copy this file to config/.env and fill in your values
# ============================================================

# ── Binance API ──────────────────────────────────────────────
BINANCE_API_KEY=your_api_key_here
BINANCE_SECRET=your_api_secret_here
BINANCE_SANDBOX=true          # true = testnet, false = mainnet

# ── Trading ──────────────────────────────────────────────────
TRADING_MODE=paper             # backtest | paper | live
TIMEFRAME=5m                   # 1m | 5m | 15m | 1h
LEVERAGE=50
CHECK_INTERVAL=30              # seconds between trading loop iterations

# ── Redis (required for EventBus) ────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=
REDIS_DB=0

# ── Monitoring ───────────────────────────────────────────────
METRICS_ENABLED=true
METRICS_PORT=9090
METRICS_HOST=0.0.0.0

# ── Tracing (OpenTelemetry) ──────────────────────────────────
ENABLE_TRACING=false
TRACING_SERVICE_NAME=quant-algo
TRACING_ENDPOINT=http://localhost:4318/v1/traces
TRACING_SAMPLING_RATE=1.0

# ── AI / LLM ────────────────────────────────────────────────
AI_PROVIDER=deepseek
AI_FALLBACK_ENABLED=true
AI_TIMEOUT=30000
AI_MAX_RETRIES=3
AI_CACHE_ENABLED=true
AI_CACHE_TTL=300000
AI_TOKEN_LIMIT=100000
