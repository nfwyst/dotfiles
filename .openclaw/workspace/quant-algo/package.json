{
  "name": "quant-algo",
  "version": "1.0.0",
  "description": "Event-driven quantitative trading system with OCS signal engine, Bayesian risk management, and CPCV validation",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit && echo '\u2705 Type check passed'",
    "start": "tsx src/index.ts",
    "start:live": "TRADING_MODE=live tsx src/index.ts",
    "start:paper": "TRADING_MODE=paper tsx src/index.ts",
    "backtest": "tsx backtest-runner.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ci": "vitest run --reporter=junit --outputFile=test-results.xml",
    "clean": "rm -rf dist coverage backtest-reports/*.json",
    "prepare-data": "echo '\u26a0\ufe0f  Place OHLCV JSON files in backtest-cache/ (see README.md)'",
    "backtest:fast": "BT_PHASE=A tsx backtest-runner.ts",
    "backtest:verify": "BT_PHASE=AB tsx backtest-runner.ts",
    "backtest:engine": "tsx backtest-engine.ts"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-node": "^0.214.0",
    "@opentelemetry/sdk-trace-base": "^2.6.1",
    "@opentelemetry/semantic-conventions": "^1.29.0",
    "dotenv": "^16.4.0",
    "ioredis": "^5.4.0",
    "prom-client": "^15.1.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@vitest/coverage-v8": "^1.6.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^1.6.0"
  }
}
