#!/usr/bin/env nu

# Auto-switch delta theme based on macOS system appearance
# Dark: woolly-mammoth | Light: hoopoe

def main [...rest: string] {
  let result = do { ^defaults read -g AppleInterfaceStyle } | complete
  let theme = if $result.exit_code == 0 {
    "woolly-mammoth"
  } else {
    "hoopoe"
  }
  ^delta --features $theme ...$rest
}
