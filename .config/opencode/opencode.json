{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "permission": {
    "read": "allow",
    "edit": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "bash": "allow",
    "task": "allow",
    "skill": "allow",
    "lsp": "allow",
    "todoread": "allow",
    "todowrite": "allow",
    "websearch": "allow",
    "external_directory": "allow",
    "doom_loop": "allow"
  },
  "plugin": [
    "@tarquinen/opencode-dcp@latest",
    "opencode-mem@latest",
    "oh-my-openagent@latest"
  ],
  "mcp": {
    "codin-d2c-mcp": {
      "type": "local",
      "command": [
        "bunx",
        "-y",
        "@byted/codin-d2c-mcp@latest"
      ],
      "environment": {
        "CODIN_D2C_TOKEN": "{env:CODIN_D2C_TOKEN}",
        "FIGMA_ACCESS_TOKEN": "{env:FIGMA_ACCESS_TOKEN}",
        "BUN_CONFIG_REGISTRY": "{env:BUN_CONFIG_REGISTRY}"
      },
      "timeout": 1800000,
      "enabled": false
    },
    "tradingview-mcp": {
      "type": "local",
      "command": [
        "bunx",
        "-y",
        "tradingview-mcp-server@latest"
      ],
      "timeout": 120000,
      "enabled": true
    },
    "alpha-vantage-mcp": {
      "type": "local",
      "command": [
        "bunx",
        "-y",
        "alpha-vantage-mcp@latest"
      ],
      "environment": {
        "ALPHA_VANTAGE_API_KEY": "{env:ALPHA_VANTAGE_API_KEY}"
      },
      "timeout": 120000,
      "enabled": true
    },
    "yahoo-finance-mcp": {
      "type": "local",
      "command": [
        "bunx",
        "-y",
        "yahoo-finance-mcp@latest"
      ],
      "timeout": 120000,
      "enabled": true
    }
  },
  "provider": {
    "kimi-for-coding": {
      "models": {
        "k2p5": {
          "limit": {
            "context": 262144,
            "output": 262144
          }
        }
      }
    },
    "baiduqianfancodingplan": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Qianfan Coding Plan",
      "options": {
        "baseURL": "https://qianfan.baidubce.com/v2/coding",
        "apiKey": "{env:BAIDU_QIANFAN_API_KEY}"
      },
      "models": {
        "qianfan-code-latest": {
          "name": "Qianfan Code Latest",
          "limit": {
            "context": 202752,
            "output": 131072
          }
        }
      }
    }
  }
}
