{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "permission": {
    "read": "allow",
    "edit": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "bash": "allow",
    "task": "allow",
    "skill": "allow",
    "lsp": "allow",
    "websearch": "allow",
    "webfetch": "allow",
    "codesearch": "allow",
    "external_directory": "allow",
    "doom_loop": "allow"
  },
  "plugin": [
    "./plugins/rtk.ts",
    "opencode-mem@latest",
    "opencode-plugin-preload-skills@latest",
    "@tarquinen/opencode-dcp@latest",
    "opencode-plugin-openspec@latest",
    "oh-my-openagent@latest"
  ],
  "mcp": {
    "codin-d2c-mcp": {
      "type": "local",
      "command": ["bunx", "-y", "@byted/codin-d2c-mcp@latest"],
      "environment": {
        "CODIN_D2C_TOKEN": "{env:CODIN_D2C_TOKEN}",
        "FIGMA_ACCESS_TOKEN": "{env:FIGMA_ACCESS_TOKEN}",
        "BUN_CONFIG_REGISTRY": "https://bnpm.byted.org/"
      },
      "timeout": 1800000,
      "enabled": true
    },
    "tradingview-mcp": {
      "type": "local",
      "command": ["bunx", "-y", "tradingview-mcp-server@latest"],
      "timeout": 120000,
      "enabled": true
    },
    "alpha-vantage-mcp": {
      "type": "local",
      "command": ["bunx", "-y", "alpha-vantage-mcp@latest"],
      "environment": {
        "ALPHA_VANTAGE_API_KEY": "{env:ALPHA_VANTAGE_API_KEY}"
      },
      "timeout": 120000,
      "enabled": true
    },
    "yahoo-finance-mcp": {
      "type": "local",
      "command": ["bunx", "-y", "yahoo-finance-mcp@latest"],
      "timeout": 120000,
      "enabled": true
    },
    "paper-search-mcp": {
      "type": "remote",
      "url": "https://server.smithery.ai/@openags/paper-search-mcp/mcp",
      "timeout": 120000,
      "enabled": true
    }
  },
  "provider": {
    "kimi-for-coding": {
      "models": {
        "k2p5": {
          "limit": {
            "context": 262144,
            "output": 262144
          }
        }
      }
    },
    "baiduqianfancodingplan": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Qianfan Coding Plan",
      "options": {
        "baseURL": "https://qianfan.baidubce.com/v2/coding",
        "apiKey": "{env:BAIDU_QIANFAN_API_KEY}"
      },
      "models": {
        "qianfan-code-latest": {
          "name": "Qianfan Code Latest",
          "limit": {
            "context": 202752,
            "output": 131072
          }
        }
      }
    },
    "opencode": {
      "blacklist": [
        "big-pickle",
        "claude-3-5-haiku",
        "claude-haiku-4-5",
        "claude-opus-4-1",
        "claude-opus-4-5",
        "claude-sonnet-4",
        "claude-sonnet-4-5",
        "claude-sonnet-4-6",
        "claude-opus-4-6",
        "gemini-3.1-pro",
        "glm-5",
        "glm-5.1",
        "gpt-5",
        "gpt-5-codex",
        "gpt-5-nano",
        "gpt-5.1",
        "gpt-5.1-codex",
        "gpt-5.1-codex-max",
        "gpt-5.1-codex-mini",
        "gpt-5.2",
        "gpt-5.2-codex",
        "gpt-5.3-codex",
        "gpt-5.3-codex-spark",
        "gpt-5.4-nano",
        "gpt-5.4-pro",
        "gpt-5.4-mini",
        "kimi-k2.5",
        "minimax-m2.5",
        "minimax-m2.5-free",
        "nemotron-3-super-free",
        "gemini-3-flash",
        "qwen3.6-plus",
        "qwen3.5-plus",
        "gpt-5.4",
        "kimi-k2.6",
        "minimax-m2.7"
      ]
    },
    "opencode-go": {
      "models": {
        "qwen3.6-plus": {
          "limit": {
            "context": 1000000,
            "output": 65536
          }
        },
        "kimi-k2.6": {
          "limit": {
            "context": 262144,
            "output": 262144
          }
        },
        "glm-5.1": {
          "limit": {
            "context": 200000,
            "output": 131072
          }
        },
        "minimax-m2.7": {
          "limit": {
            "context": 205000,
            "output": 131072
          }
        }
      },
      "blacklist": [
        "mimo-v2-omni",
        "minimax-m2.5",
        "qwen3.5-plus",
        "glm-5",
        "kimi-k2.5",
        "mimo-v2-pro"
      ]
    }
  },
  "disabled_providers": [
    "zhipuai-coding-plan",
    "kimi-for-coding",
    "baiduqianfancodingplan",
    "deepseek"
  ]
}
