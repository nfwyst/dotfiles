{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "permission": {
    "read": "allow",
    "edit": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "bash": "allow",
    "task": "allow",
    "skill": "allow",
    "lsp": "allow",
    "websearch": "allow",
    "webfetch": "allow",
    "codesearch": "allow",
    "external_directory": "allow",
    "doom_loop": "allow"
  },
  "instructions": ["./skills/caveman/SKILL.md"],
  "plugin": [
    "./plugins/graphify.js",
    "./plugins/rtk.ts",
    "opencode-mem@latest",
    "@tarquinen/opencode-dcp@latest",
    "opencode-plugin-openspec@latest",
    "oh-my-openagent@latest"
  ],
  "mcp": {
    "codin-d2c-mcp": {
      "type": "local",
      "command": ["bunx", "-y", "@byted/codin-d2c-mcp@latest"],
      "environment": {
        "CODIN_D2C_TOKEN": "{env:CODIN_D2C_TOKEN}",
        "FIGMA_ACCESS_TOKEN": "{env:FIGMA_ACCESS_TOKEN}",
        "BUN_CONFIG_REGISTRY": "https://bnpm.byted.org/"
      },
      "timeout": 120000,
      "enabled": true
    },
    "meego": {
      "type": "local",
      "command": [
        "bunx",
        "-y",
        "@lark-project/mcp@latest",
        "--domain",
        "https://meego.larkoffice.com"
      ],
      "environment": {
        "MCP_USER_TOKEN": "{env:MEEGO_MCP_USER_TOKEN}",
        "DOTENV_CONFIG_QUIET": "1",
        "BUN_CONFIG_REGISTRY": "https://bnpm.byted.org/"
      },
      "timeout": 120000,
      "enabled": false
    },
    "tradingview-mcp": {
      "type": "local",
      "command": ["bunx", "-y", "tradingview-mcp-server@latest"],
      "timeout": 120000,
      "enabled": true
    },
    "alpha-vantage-mcp": {
      "type": "local",
      "command": ["bunx", "-y", "alpha-vantage-mcp@latest"],
      "environment": {
        "ALPHA_VANTAGE_API_KEY": "{env:ALPHA_VANTAGE_API_KEY}"
      },
      "timeout": 120000,
      "enabled": false
    },
    "yahoo-finance-mcp": {
      "type": "local",
      "command": ["bunx", "-y", "yahoo-finance-mcp@latest"],
      "timeout": 120000,
      "enabled": true
    },
    "paper-search-mcp": {
      "type": "remote",
      "url": "https://server.smithery.ai/@openags/paper-search-mcp/mcp",
      "timeout": 120000,
      "enabled": true
    }
  },
  "provider": {
    "opencode": {
      "blacklist": [
        "big-pickle",
        "claude-3-5-haiku",
        "claude-haiku-4-5",
        "claude-opus-4-1",
        "claude-opus-4-5",
        "claude-sonnet-4",
        "claude-sonnet-4-5",
        "claude-sonnet-4-6",
        "claude-opus-4-6",
        "gemini-3.1-pro",
        "glm-5",
        "glm-5.1",
        "gpt-5",
        "gpt-5-codex",
        "gpt-5-nano",
        "gpt-5.1",
        "gpt-5.1-codex",
        "gpt-5.1-codex-max",
        "gpt-5.1-codex-mini",
        "gpt-5.2",
        "gpt-5.2-codex",
        "gpt-5.3-codex",
        "gpt-5.3-codex-spark",
        "gpt-5.4-nano",
        "gpt-5.4-pro",
        "gpt-5.4-mini",
        "kimi-k2.5",
        "minimax-m2.5",
        "minimax-m2.5-free",
        "nemotron-3-super-free",
        "gemini-3-flash",
        "qwen3.6-plus",
        "qwen3.5-plus",
        "gpt-5.4",
        "kimi-k2.6",
        "minimax-m2.7",
        "ling-2.6-flash-free",
        "hy3-preview-free",
        "gpt-5.5",
        "gpt-5.5-pro"
      ]
    },
    "opencode-go": {
      "blacklist": [
        "mimo-v2-omni",
        "minimax-m2.5",
        "qwen3.5-plus",
        "glm-5",
        "kimi-k2.5",
        "mimo-v2-pro",
        "mimo-v2.5",
        "deepseek-v4-flash"
      ]
    },
    "deepseek": {
      "blacklist": ["deepseek-chat", "deepseek-reasoner", "deepseek-v4-flash"]
    }
  },
  "disabled_providers": [
    "zhipuai-coding-plan",
    "kimi-for-coding",
    "google",
    "openai",
    "openrouter",
    "google-vertex-anthropic",
    "google-vertex"
  ]
}
