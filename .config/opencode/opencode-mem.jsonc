{
  // 存储路径
  "storagePath": "~/.opencode-mem/data",

  // Ollama 嵌入模型配置
  "embeddingModel": "qwen3-embedding:latest",
  "embeddingDimensions": 4096,
  "embeddingApiUrl": "http://localhost:11434/v1",
  "embeddingApiKey": "ollama",

  // Web UI 配置
  "webServerEnabled": true,
  "webServerPort": 4747,

  // 自动捕获记忆
  "autoCaptureEnabled": true,
  "autoCaptureLanguage": "auto",

  // 记忆提取 AI 配置 (使用 Ollama 本地模型)
  "memoryProvider": "openai-chat",
  "memoryModel": "qwen3.5:35b",
  "memoryApiUrl": "http://localhost:11434/v1",
  "memoryApiKey": "ollama",
  "memoryTemperature": 0.3,

  // 提示配置
  "showAutoCaptureToasts": true,
  "showUserProfileToasts": true,
  "showErrorToasts": true,

  // 用户画像分析间隔 (每 N 次会话分析一次)
  "userProfileAnalysisInterval": 10,

  // 最大记忆数
  "maxMemories": 100,

  // 压缩配置
  "compaction": {
    "enabled": true,
    "memoryLimit": 20
  },

  // 聊天消息记忆注入
  "chatMessage": {
    "enabled": true,
    "maxMemories": 5,
    "excludeCurrentSession": true,
    "injectOn": "first"
  }
}
